# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables and secrets
.env
.env.*

# Logs
*.log

# Keep the logs folder, but ignore generated log files
logs/*.log
!logs/.gitkeep

# Generated CSV outputs
data/*.csv
!data/.gitkeep

# Keep screenshots folder available for portfolio images
!screenshots/.gitkeep

# Operating system files
.DS_Store
Thumbs.db
desktop.ini

# Editor folders
.vscode/
.idea/

# Test and tooling cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
